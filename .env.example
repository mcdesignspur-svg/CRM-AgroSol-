# PostgreSQL — copia a .env y ajusta según tu entorno
DATABASE_URL="postgresql://agrosol:agrosol@localhost:5432/agrosol_crm?schema=public"

# URL directa para migraciones Prisma (obligatoria si usas connection pooling).
# En local con Docker, puede ser la misma que DATABASE_URL.
DIRECT_DATABASE_URL="postgresql://agrosol:agrosol@localhost:5432/agrosol_crm?schema=public"

# Neon en Vercel:
# - DATABASE_URL: URL pooled (con "-pooler" en el host) para la app en runtime
# - DIRECT_DATABASE_URL: URL directa (sin "-pooler") para `prisma migrate deploy`
