# PostgreSQL — copia a .env y ajusta según tu entorno
DATABASE_URL="postgresql://agrosol:agrosol@localhost:5432/agrosol_crm?schema=public"

# Neon en Vercel: usa la URL pooled para la app (DATABASE_URL).
# Para migraciones locales contra Neon, usa la URL directa (sin "-pooler" en el host):
# DIRECT_DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Loyverse POS / ERP
# Token personal: https://r.loyverse.com/dashboard/#/integrations/tokens
LOYVERSE_ACCESS_TOKEN=""
LOYVERSE_API_BASE_URL="https://api.loyverse.com/v1.0"
LOYVERSE_RECEIPT_SOURCE="AgroSol CRM"
# Secreto opcional para validar webhooks entrantes
LOYVERSE_WEBHOOK_SECRET=""
