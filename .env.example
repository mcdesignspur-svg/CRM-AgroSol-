# PostgreSQL — copia a .env y ajusta según tu entorno
DATABASE_URL="postgresql://agrosol:agrosol@localhost:5432/agrosol_crm?schema=public"

# Neon (u otro proveedor con connection pooling):
#
# DATABASE_URL — URL pooled (host con "-pooler"), usada por la app en runtime y por
# `prisma migrate deploy` en el build de Vercel (scripts/vercel-build.mjs).
# En Vercel, configúrala en Production (y Preview si aplica).
#
# DIRECT_DATABASE_URL — URL directa (sin "-pooler"), opcional en local.
# Úsala solo si necesitas ejecutar migraciones o Prisma Studio contra Neon desde tu
# máquina; el schema de Prisma no la referencia hoy — las migraciones usan DATABASE_URL.
#
# Ejemplo Neon:
# DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# DIRECT_DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
