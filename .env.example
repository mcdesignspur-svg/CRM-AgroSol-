# PostgreSQL — copia a .env y ajusta según tu entorno
DATABASE_URL="postgresql://agrosol:agrosol@localhost:5432/agrosol_crm?schema=public"

# Loyverse — Gurabo (Central). Futuro: un token por sucursal.
LOYVERSE_ACCESS_TOKEN=""
# LOYVERSE_ACCESS_TOKEN_SAN_LORENZO=""
# LOYVERSE_ACCESS_TOKEN_NAVARRO=""

# Neon (u otro proveedor con connection pooling):
#
# DATABASE_URL — URL pooled (host con "-pooler"), usada por la app en runtime.
# En Vercel, configúrala en Production (y Preview si aplica).
#
# DIRECT_DATABASE_URL — URL directa (sin "-pooler"). Configúrala en Vercel
# Production: el build (scripts/vercel-build.mjs) la usa para `prisma migrate deploy`,
# porque las migraciones necesitan una conexión directa (los advisory locks de
# Prisma Migrate fallan con timeout P1002 a través del pooler).
# Los builds de preview NO ejecutan migraciones.
#
# Ejemplo Neon:
# DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# DIRECT_DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
