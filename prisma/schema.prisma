generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BranchStatus {
  online
  offline
  warning
}

enum OrderType {
  entrega
  retiro
}

enum OrderStatus {
  pendiente
  en_transito
  listo
  atrasado
  completado
}

enum PingPriority {
  urgente
  sistema
  advertencia
}

enum DeliveryStatus {
  recogida
  entrega
}

model Branch {
  id              String       @id
  name            String
  address         String
  phone           String?
  capacityPercent Int          @default(0) @map("capacity_percent")
  currentVolume   Int          @default(0) @map("current_volume")
  status          BranchStatus @default(online)
  lastPingAt      DateTime?    @map("last_ping_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  orders              Order[]
  deliveries          Delivery[]
  products            Product[]
  productCategories   ProductCategory[]
  loyverseIntegration LoyverseIntegration?

  @@map("branches")
}

model ProductCategory {
  id        String    @id
  branchId  String    @map("branch_id")
  name      String
  active    Boolean   @default(true)
  syncedAt  DateTime? @map("synced_at")
  createdAt DateTime  @default(now()) @map("created_at")

  branch   Branch    @relation(fields: [branchId], references: [id])
  products Product[]

  @@index([branchId, name])
  @@index([branchId, active])
  @@map("product_categories")
}

model Product {
  id                String    @id @default(cuid())
  branchId          String    @default("gurabo") @map("branch_id")
  categoryId        String?   @map("category_id")
  name              String
  sku               String
  unitPrice         Decimal   @map("unit_price") @db.Decimal(10, 2)
  stockQuantity     Int?      @map("stock_quantity")
  loyverseItemId    String?   @map("loyverse_item_id")
  loyverseVariantId String?   @map("loyverse_variant_id")
  active            Boolean   @default(true)
  syncedAt          DateTime? @map("synced_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  branch     Branch           @relation(fields: [branchId], references: [id])
  category   ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems OrderLineItem[]

  @@unique([branchId, sku])
  @@index([branchId, name])
  @@index([branchId, active])
  @@index([branchId, categoryId])
  @@map("products")
}

model LoyverseIntegration {
  branchId              String    @id @map("branch_id")
  merchantName          String?   @map("merchant_name")
  productCount          Int       @default(0) @map("product_count")
  lastFullSyncAt        DateTime? @map("last_full_sync_at")
  lastIncrementalSyncAt DateTime? @map("last_incremental_sync_at")
  lastInventorySyncAt   DateTime? @map("last_inventory_sync_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  branch Branch @relation(fields: [branchId], references: [id])

  @@map("loyverse_integrations")
}

model Order {
  id              String      @id @default(cuid())
  displayId       String      @unique @map("display_id")
  customerName    String      @map("customer_name")
  customerPhone   String?     @map("customer_phone")
  deliveryAddress String?     @map("delivery_address")
  type            OrderType
  branchId        String      @map("branch_id")
  status          OrderStatus @default(pendiente)
  fulfillment     String      @default("pickup")
  smsNotify       Boolean     @default(false) @map("sms_notify")
  pickupToken             String?     @unique @map("pickup_token")
  telegramChatId          String?     @map("telegram_chat_id")
  arrivedAt               DateTime?   @map("arrived_at")
  confirmationNotifiedAt  DateTime?   @map("confirmation_notified_at")
  readyNotifiedAt         DateTime?   @map("ready_notified_at")
  subtotal        Decimal     @db.Decimal(12, 2)
  taxes           Decimal     @db.Decimal(12, 2)
  deliveryFee     Decimal     @default(0) @map("delivery_fee") @db.Decimal(12, 2)
  total           Decimal     @db.Decimal(12, 2)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  branch    Branch          @relation(fields: [branchId], references: [id])
  lineItems OrderLineItem[]
  delivery  Delivery?

  @@index([createdAt(sort: Desc)])
  @@index([status])
  @@index([branchId])
  @@index([fulfillment])
  @@map("orders")
}

model OrderLineItem {
  id        String  @id @default(cuid())
  orderId   String  @map("order_id")
  productId String? @map("product_id")
  name      String
  sku       String
  unitPrice Decimal @map("unit_price") @db.Decimal(10, 2)
  quantity  Int

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("order_line_items")
}

model Delivery {
  id             String         @id @default(cuid())
  displayId      String         @unique @map("display_id")
  driverName     String         @map("driver_name")
  driverInitials String         @map("driver_initials")
  destination    String
  eta            String?
  status         DeliveryStatus
  branchId       String?        @map("branch_id")
  orderId        String?        @unique @map("order_id")
  createdAt      DateTime       @default(now()) @map("created_at")

  branch Branch? @relation(fields: [branchId], references: [id])
  order  Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([branchId])
  @@map("deliveries")
}

model Ping {
  id          String       @id @default(cuid())
  priority    PingPriority
  title       String
  description String
  dismissed   Boolean      @default(false)
  createdAt   DateTime     @default(now()) @map("created_at")

  @@index([dismissed, createdAt(sort: Desc)])
  @@map("pings")
}

model NotificationLog {
  id        String   @id @default(cuid())
  source    String
  message   String
  accent    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt(sort: Desc)])
  @@map("notification_logs")
}
